<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Pou Online Multiplayer</title>
    <link rel="stylesheet" href="assets/css/style.css">
</head>
<body>

    <!-- Tela de Autenticação Anônima -->
    <div id="auth-screen" class="screen active">
        <div class="auth-box">
            <h1>Pou Multiplayer 🌟</h1>
            <p>Escolha um nome para o seu Pou:</p>
            <input type="text" id="pou-nickname-input" placeholder="Ex: PouDoLippezin">
            <br>
            <button id="btn-play-guest">JOGAR AGORA</button>
        </div>
    </div>

    <!-- Tela Principal do Jogo -->
    <div id="game-screen" class="screen">
        <!-- HUD Superior -->
        <header id="hud">
            <div class="stats-grid">
                <div class="stat-bar"><span class="icon">🍖</span><div class="progress"><div id="bar-hunger" class="fill"></div></div></div>
                <div class="stat-bar"><span class="icon">❤️</span><div class="progress"><div id="bar-health" class="fill"></div></div></div>
                <div class="stat-bar"><span class="icon">🕹️</span><div class="progress"><div id="bar-fun" class="fill"></div></div></div>
                <div class="stat-bar"><span class="icon">⚡</span><div class="progress"><div id="bar-energy" class="fill"></div></div></div>
            </div>
            <div class="user-info">
                <span id="pou-name">Pou</span>
                <span id="pou-level">Nível: 1</span>
                <span id="pou-coins">🪙 0</span>
            </div>
        </header>

        <!-- Container do Cômodo Atual -->
        <main id="room-container">
            <button id="nav-left" class="nav-btn">◀</button>
            <div id="room-content" class="kitchen">
                <div id="pou-character" class="happy">
                    <div class="eyes">
                        <div class="eye left"><div class="pupil"></div></div>
                        <div class="eye right"><div class="pupil"></div></div>
                    </div>
                    <div class="mouth"></div>
                </div>
            </div>
            <button id="nav-right" class="nav-btn">▶</button>
        </main>

        <!-- Menu Inferior / Aba Social -->
        <footer id="game-menu">
            <button id="btn-open-social">🌐 Mundo Online</button>
            <button id="btn-save-account">💾 Salvar Progresso (Google)</button>
        </footer>
    </div>

    <!-- Modal Social / Multiplayer -->
    <div id="social-modal" class="modal">
        <div class="modal-content">
            <span class="close-btn">&times;</span>
            <h2>Mundo Multiplayer</h2>
            <div class="social-tabs">
                <button id="tab-leaderboard" class="active">Ranking Global</button>
            </div>
            <div id="social-body"></div>
        </div>
    </div>

    <!-- Injeção Estruturada de Módulos Core -->
    <script type="module" src="../src/multiplayer/Auth.js"></script>
    <script type="module" src="../src/core/RoomManager.js"></script>
</body>
</html>
